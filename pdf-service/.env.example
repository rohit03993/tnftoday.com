# Copy to .env on the VPS and set strong random values (never commit .env).

REDIS_URL=redis://127.0.0.1:6379/0
S3_ENDPOINT_URL=https://your-s3-endpoint
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=us-east-1
S3_BUCKET_PDFS=tnf-pdfs
S3_BUCKET_IMAGES=tnf-images

# Must match TNF_PDF_SERVICE_SECRET in WordPress wp-config.php
SERVICE_SECRET=CHANGE_ME_pdf_service_secret

# Must match TNF_WP_CALLBACK_SECRET in WordPress wp-config.php
WP_CALLBACK_SECRET=CHANGE_ME_wp_callback_secret
WORDPRESS_CALLBACK_URL=https://tnftoday.com/wp-json/tnf/v1/internal/pdf-job-complete

RENDER_DPI=120
