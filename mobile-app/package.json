{
  "name": "tnf-today-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "TNF Today Android app (Capacitor shell loading live production site)",
  "scripts": {
    "cap:sync": "npx cap sync android",
    "cap:copy": "npx cap copy android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
