# Parent theme: ship only our homepage pattern override; core theme comes from WordPress
wordpress/wp-content/themes/twentytwentyfive/*
!wordpress/wp-content/themes/twentytwentyfive/patterns/
wordpress/wp-content/themes/twentytwentyfive/patterns/*
!wordpress/wp-content/themes/twentytwentyfive/patterns/template-home-with-sidebar-news-blog.php

# Default WP placeholder index files (optional; harmless if omitted from git)
wordpress/wp-content/index.php
wordpress/wp-content/plugins/index.php
wordpress/wp-content/themes/index.php

# Demo seeder: add to git when you want it on GitHub (remove this line to track)
wordpress/wp-content/plugins/tnf-dummy-content/
